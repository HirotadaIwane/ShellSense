{
  "version": "2.0.0",
  "metadata": {
    "layer": "core",
    "name": "system",
    "description": "System administration"
  },
  "commands": {
    "chmod": {
      "name": "chmod",
      "description": {
        "ja": "ファイルやフォルダのアクセス権限を変更",
        "en": "Change file mode bits"
      },
      "baseRisk": "high",
      "category": "system",
      "flags": {
        "-R": {
          "description": { "ja": "フォルダ内を再帰的に権限変更", "en": "Change permissions recursively" },
          "riskModifier": "high"
        }
      }
    },
    "uptime": {
      "name": "uptime",
      "description": {
        "ja": "システムの稼働時間と負荷平均を表示",
        "en": "Show system uptime and load averages"
      },
      "baseRisk": "low",
      "category": "system",
      "flags": {
        "-p": {
          "description": { "ja": "読みやすい形式で表示", "en": "Pretty format" }
        },
        "-s": {
          "description": { "ja": "起動日時を表示", "en": "Show boot time" }
        }
      }
    },
    "whoami": {
      "name": "whoami",
      "description": {
        "ja": "現在のユーザー名を表示",
        "en": "Print current user name"
      },
      "baseRisk": "low",
      "category": "system",
      "flags": {}
    },
    "id": {
      "name": "id",
      "description": {
        "ja": "ユーザーのUID・GID・グループ情報を表示",
        "en": "Print user and group information"
      },
      "baseRisk": "low",
      "category": "system",
      "flags": {
        "-g": {
          "description": { "ja": "グループIDのみ", "en": "Print group ID only" }
        },
        "-G": {
          "description": { "ja": "全グループID表示", "en": "Print all group IDs" }
        },
        "-n": {
          "description": { "ja": "IDの代わりに名前を表示", "en": "Print name instead of number" }
        },
        "-u": {
          "description": { "ja": "ユーザーIDのみ", "en": "Print user ID only" }
        }
      }
    },
    "date": {
      "name": "date",
      "description": {
        "ja": "システムの日付・時刻を表示・設定",
        "en": "Display or set system date and time"
      },
      "baseRisk": "low",
      "category": "system",
      "flags": {
        "-d": {
          "description": { "ja": "指定日付を表示", "en": "Display specified date" }
        },
        "-I": {
          "description": { "ja": "ISO 8601形式で表示", "en": "Output in ISO 8601 format" }
        },
        "-R": {
          "description": { "ja": "RFC 5322形式で表示", "en": "Output in RFC 5322 format" }
        },
        "-s": {
          "description": { "ja": "システム日時を設定", "en": "Set system date and time" },
          "riskModifier": "critical"
        },
        "-u": {
          "description": { "ja": "UTCで表示", "en": "Display in UTC" }
        }
      }
    },
    "cal": {
      "name": "cal",
      "description": {
        "ja": "カレンダーを表示",
        "en": "Display a calendar"
      },
      "baseRisk": "low",
      "category": "system",
      "flags": {
        "-3": {
          "description": { "ja": "前月・当月・翌月を表示", "en": "Show three months" }
        },
        "-y": {
          "description": { "ja": "年間カレンダー表示", "en": "Show full year" }
        },
        "-m": {
          "description": { "ja": "週始まりを月曜に", "en": "Start week on Monday" }
        },
        "-j": {
          "description": { "ja": "ユリウス日表示", "en": "Show Julian days" }
        }
      }
    },
    "chown": {
      "name": "chown",
      "description": {
        "ja": "ファイルの所有者・グループを変更",
        "en": "Change file owner and group"
      },
      "baseRisk": "high",
      "category": "system",
      "flags": {
        "-R": {
          "description": { "ja": "再帰的に変更", "en": "Change recursively" },
          "riskModifier": "high"
        },
        "-v": {
          "description": { "ja": "変更の詳細を表示", "en": "Verbose output" }
        },
        "-c": {
          "description": { "ja": "変更があった場合のみ表示", "en": "Report only changes" }
        },
        "-h": {
          "description": { "ja": "シンボリックリンク自体を変更", "en": "Change symlink itself" }
        },
        "--reference": {
          "description": { "ja": "参照ファイルと同じ所有者に変更", "en": "Copy owner from reference file" }
        }
      }
    },
    "chgrp": {
      "name": "chgrp",
      "description": {
        "ja": "ファイルのグループを変更",
        "en": "Change file group ownership"
      },
      "baseRisk": "high",
      "category": "system",
      "flags": {
        "-R": {
          "description": { "ja": "再帰的に変更", "en": "Change recursively" },
          "riskModifier": "high"
        },
        "-v": {
          "description": { "ja": "変更の詳細を表示", "en": "Verbose output" }
        },
        "-c": {
          "description": { "ja": "変更があった場合のみ表示", "en": "Report only changes" }
        },
        "-h": {
          "description": { "ja": "シンボリックリンク自体を変更", "en": "Change symlink itself" }
        }
      }
    },
    "su": {
      "name": "su",
      "description": {
        "ja": "ユーザーを切り替える",
        "en": "Switch user identity"
      },
      "baseRisk": "critical",
      "category": "system",
      "flags": {
        "-l": {
          "description": { "ja": "ログインシェルとして切り替え", "en": "Start login shell" }
        },
        "-c": {
          "description": { "ja": "コマンドを実行して終了", "en": "Run command and exit" },
          "riskModifier": "critical"
        },
        "-s": {
          "description": { "ja": "使用するシェルを指定", "en": "Specify shell" }
        },
        "-m": {
          "description": { "ja": "環境変数を保持", "en": "Preserve environment" }
        }
      }
    },
    "top": {
      "name": "top",
      "description": {
        "ja": "リアルタイムでプロセス情報を表示",
        "en": "Display real-time process information"
      },
      "baseRisk": "low",
      "category": "system",
      "flags": {
        "-b": {
          "description": { "ja": "バッチモード", "en": "Batch mode" }
        },
        "-n": {
          "description": { "ja": "更新回数を指定", "en": "Set number of iterations" }
        },
        "-d": {
          "description": { "ja": "更新間隔を指定", "en": "Set refresh interval" }
        },
        "-p": {
          "description": { "ja": "PID指定で監視", "en": "Monitor specific PID" }
        },
        "-u": {
          "description": { "ja": "ユーザー指定でフィルター", "en": "Filter by user" }
        }
      }
    },
    "free": {
      "name": "free",
      "description": {
        "ja": "メモリの使用状況を表示",
        "en": "Display memory usage information"
      },
      "baseRisk": "low",
      "category": "system",
      "flags": {
        "-h": {
          "description": { "ja": "読みやすい単位で表示", "en": "Human-readable sizes" }
        },
        "-m": {
          "description": { "ja": "メガバイト単位", "en": "Show in megabytes" }
        },
        "-g": {
          "description": { "ja": "ギガバイト単位", "en": "Show in gigabytes" }
        },
        "-t": {
          "description": { "ja": "合計行を表示", "en": "Show total" }
        },
        "-s": {
          "description": { "ja": "指定間隔で繰り返し表示", "en": "Repeat at interval" }
        }
      }
    },
    "uname": {
      "name": "uname",
      "description": {
        "ja": "システム情報を表示",
        "en": "Print system information"
      },
      "baseRisk": "low",
      "category": "system",
      "flags": {
        "-a": {
          "description": { "ja": "全情報表示", "en": "Print all information" }
        },
        "-s": {
          "description": { "ja": "カーネル名表示", "en": "Print kernel name" }
        },
        "-r": {
          "description": { "ja": "カーネルリリース表示", "en": "Print kernel release" }
        },
        "-m": {
          "description": { "ja": "マシンアーキテクチャ表示", "en": "Print machine architecture" }
        }
      }
    },
    "hostname": {
      "name": "hostname",
      "description": {
        "ja": "ホスト名を表示・設定",
        "en": "Show or set system hostname"
      },
      "baseRisk": "low",
      "category": "system",
      "flags": {
        "-f": {
          "description": { "ja": "FQDN表示", "en": "Show fully qualified domain name" }
        },
        "-i": {
          "description": { "ja": "IPアドレス表示", "en": "Show IP address" }
        },
        "-I": {
          "description": { "ja": "全IPアドレス表示", "en": "Show all IP addresses" }
        },
        "-s": {
          "description": { "ja": "短いホスト名表示", "en": "Show short hostname" }
        }
      }
    },
    "crontab": {
      "name": "crontab",
      "description": {
        "ja": "定期実行ジョブ（cron）を管理します",
        "en": "Manage cron job schedules"
      },
      "baseRisk": "medium",
      "category": "system",
      "flags": {
        "-e": {
          "description": { "ja": "エディタでcronジョブを編集", "en": "Edit crontab using editor" },
          "riskModifier": "medium"
        },
        "-l": {
          "description": { "ja": "現在のcronジョブ一覧を表示", "en": "List current cron jobs" }
        },
        "-r": {
          "description": { "ja": "全てのcronジョブを削除", "en": "Remove all cron jobs" },
          "riskModifier": "high"
        },
        "-u": {
          "description": { "ja": "指定ユーザーのcrontabを操作", "en": "Operate on specified user's crontab" }
        }
      }
    }
  }
}
