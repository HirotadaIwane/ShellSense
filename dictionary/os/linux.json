    "apt": {
      "name": "apt",
      "description": {
        "ja": "Debian/Ubuntu系のパッケージを管理します",
        "en": "Manage packages on Debian/Ubuntu systems"
      },
      "baseRisk": "medium",
      "category": "package",
      "subcommands": {
        "install": {
          "description": { "ja": "パッケージをインストール", "en": "Install packages" },
          "riskOverride": "medium"
        },
        "remove": {
